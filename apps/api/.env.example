# Postgres: prefer connection pooler string from Supabase for server-side workloads.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Issuer used by go-oidc (default derives from SUPABASE_URL if unset)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1

# Comma-separated browser origins allowed to call this API (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Railway / production: set PORT if platform injects a numeric port without ":" prefix
# PORT=8080
