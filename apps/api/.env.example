# Local: copy to .env in this folder (apps/api), then:
#   cd apps/api && go run ./cmd/server
# Listens on http://localhost:8080 (matches NEXT_PUBLIC_API_URL in apps/web).

# --- DATABASE_URL (Supabase) ---
# Use the password from: Supabase Dashboard → Project Settings → Database
# ("Database password" — the one you chose when creating the project, or after a reset).
#
# IMPORTANT — IPv4 networks (most home/office Wi‑Fi):
# The direct host db.<project-ref>.supabase.co:5432 is often IPv6-only. If you see
# "no route to host" or IPv6 dial errors, use the Session pooler string instead:
#   Dashboard → Project Settings → Database → Connection string → Tab "Session pooler"
# Typical shape (copy from dashboard — region/host vary):
#   postgresql://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@aws-0-<REGION>.pooler.supabase.com:6543/postgres
#
# URL-encode special characters in the password (e.g. @ → %40, # → %23, / → %2F).
#
# Direct connection (often IPv6-only; avoid on IPv4-only networks):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
#
# Best default for local + server: paste the full URI from the Session pooler tab (do not edit host/user unless you know the format):
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Comma-separated browser origins allowed to call this API (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: if set, POST /api/v1/slots requires header X-Slot-Admin-Key with this value.
# Leave unset for local demo so any signed-in user can add slots from the UI.
# SLOT_CREATE_SECRET=w/SoGrVrKgN+KnhQmCKWyFbmzQf/wqrRxQKfKj1POEg=

# Railway / production: set PORT if platform injects a numeric port without ":" prefix
# PORT=8080

# --- pgx pool (keep below Supabase Postgres + pooler limits) ---
# DB_MAX_CONNS=25

# --- Optional: POST /api/v1/benchmark/booking-rush ---
# Default public cap: 10_000 (browser UI matches). Lower BENCHMARK_MAX_N to tighten. With BENCHMARK_SECRET + X-Benchmark-Key, cap is BENCHMARK_HARD_MAX_N (default 10000).
# BENCHMARK_SECRET=your-long-random-string
# BENCHMARK_MAX_N=10000
# BENCHMARK_HARD_MAX_N=10000

# Per-request timeout for normal API routes (benchmark route uses 5m separately)
# REQUEST_TIMEOUT=15s
